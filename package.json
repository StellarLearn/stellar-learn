{
  "name": "stellar-learn",
  "private": true,
  "description": "Decentralized learn-to-earn platform for African blockchain developers, powered by Stellar and Soroban",
  "repository": {
    "type": "git",
    "url": "https://github.com/StellarLearn/stellar-learn.git"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.12",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
